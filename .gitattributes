# Windows scripts are encoding-sensitive (Korean BOM + CRLF for goto labels).
# Mark binary so git stores EXACT bytes and never re-normalizes/strips them.
# (CLAUDE.md STEP 7 repo hygiene.)
*.bat   binary
*.cmd   binary
*.ps1   binary
*.vbs   binary

# Media / fonts: binary.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.mp3 binary
*.wav binary
*.mp4 binary
*.mov binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary

# Shell scripts + git hooks: 반드시 LF (CRLF면 sh가 "bad interpreter"로 hook/스크립트 죽음).
*.sh         text eol=lf
.githooks/** text eol=lf
