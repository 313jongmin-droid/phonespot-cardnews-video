// ============ 상태 ============
let currentCopies = [];
let selectedCopies = new Set();
let activeCopies = []; // 라이브러리용 활성 카피
let library = [];

// ============ 유틸 ============
function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function fillSlots(template, ctx) {
  return template.replace(/\{(\w+)\}/g, (_, key) => {
    if (key === '제품') return ctx.product;
    if (key === 'USP') return ctx.usp;
    if (key === '타겟') return ctx.targetText || pick(SLOT_VALUES['타겟']);
    // 감정어: 폼의 강조 감정값 매칭
    if (key === '감정어') {
      const emo = ctx.emotion;
      const wordsForEmo = (emo && EMOTION_WORDS[emo]) ? EMOTION_WORDS[emo] : null;
      const allWords = Object.values(EMOTION_WORDS).flat();
      return wordsForEmo ? pick(wordsForEmo) : pick(allWords);
    }
    // 타겟어: 연령·성별 결합 호명
    if (key === '타겟어') {
      const ageWords = TARGET_WORDS[ctx.age] || [];
      const genderWords = (ctx.gender && ctx.gender !== '전체') ? (TARGET_WORDS[ctx.gender] || []) : [];
      const combined = [...ageWords, ...genderWords];
      return combined.length > 0 ? pick(combined) : pick(SLOT_VALUES['타겟']);
    }
    // 키워드: 폼 추가 키워드 (쉼표 분리)
    if (key === '키워드') {
      const list = (ctx.keywords || '').split(',').map(s => s.trim()).filter(Boolean);
      return list.length > 0 ? pick(list) : pick(SLOT_VALUES['타겟']);
    }
    if (SLOT_VALUES[key]) return pick(SLOT_VALUES[key]);
    return `{${key}}`;
  });
}
function pickSubset(arr, min, max) {
  const count = min + Math.floor(Math.random() * (max - min + 1));
  return shuffle(arr).slice(0, count);
}
function setSelectValue(id, value) {
  const el = document.getElementById(id);
  if (!el) return;
  for (const opt of el.options) {
    if (opt.value === value || opt.text === value) { el.value = opt.value; return; }
  }
}
function setCheckboxGroup(containerId, values) {
  document.querySelectorAll(`#${containerId} input[type=checkbox]`).forEach(el => {
    el.checked = values.includes(el.value);
  });
}

// ============ 탭 ============
function switchTab(name) {
  document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(el => el.classList.remove('active'));
  const tabs = document.querySelectorAll('.tab');
  const map = { 'copy': 0, 'library': 1, 'benchmark': 2, 'settings': 3 };
  if (map[name] !== undefined && tabs[map[name]]) tabs[map[name]].classList.add('active');
  const panel = document.getElementById('panel-' + name);
  if (panel) panel.classList.add('active');
  // 벤치마크 탭 첫 진입 시 한 번 자동 로드
  if (name === 'benchmark' && !window._benchmarkLoadedOnce) {
    window._benchmarkLoadedOnce = true;
    loadBenchmarkFromSheet();
  }
}

// ============ 🎯 벤치마크 탭 (Apify Meta Ad Library) ============
let benchmarkResults = [];      // 현재 검색 결과
let benchmarkSelected = new Set(); // 선택된 인덱스

function searchBenchmark() {
  if (!isAppsScriptWebApp()) {
    alert('Web App 환경에서만 작동 (Apify는 Apps Script가 호출)');
    return;
  }
  const kw = document.getElementById('bm-keyword').value.trim();
  if (!kw) { alert('검색 키워드 입력'); return; }
  const country = (document.getElementById('bm-country').value || 'KR').toUpperCase();
  const count = parseInt(document.getElementById('bm-count').value) || 20;
  const statusEl = document.getElementById('bm-status');
  statusEl.innerHTML = `⏳ Apify 호출 중... (${count}건, 예상 비용 $${(count*0.00075).toFixed(4)} / 약 30~60초)`;
  benchmarkResults = []; benchmarkSelected.clear();
  document.getElementById('bm-results').innerHTML = '<div class="info-box">로딩 중...</div>';

  google.script.run
    .withSuccessHandler(function(res) {
      if (!res || !res.ok) {
        statusEl.innerHTML = `❌ ${res?.error || '실패'}`;
        document.getElementById('bm-results').innerHTML = `<div class="info-box" style="color:#c62828">❌ ${res?.error || '알 수 없는 오류'}</div>`;
        return;
      }
      benchmarkResults = res.items || [];
      statusEl.innerHTML = `✅ 수신 ${res.totalReceived}건 (★★★ ${benchmarkResults.filter(x => x.grade.startsWith('★★★')).length}건)`;
      renderBenchmarkResults();
      renderBenchmarkAnalysis();
    })
    .withFailureHandler(function(err) {
      statusEl.innerHTML = `❌ ${err.message || err}`;
      document.getElementById('bm-results').innerHTML = `<div class="info-box" style="color:#c62828">❌ ${err.message || err}</div>`;
    })
    .searchBenchmarkViaApify(kw, count, country);
}

function loadBenchmarkFromSheet() {
  // 시트에 누적된 벤치마크를 generator.html 라이브러리(library)로 가져옴 — 이미 library 통합 로직 있으니
  // 여기서는 시트의 BM-XXX들을 다시 검색 UI에 표시
  if (!isAppsScriptWebApp()) { alert('Web App 환경 필요'); return; }
  const statusEl = document.getElementById('bm-status');
  statusEl.innerHTML = '⏳ 시트에서 누적 벤치마크 로드 중...';
  // 현재는 시트 직접 읽기 API 미구현. library 배열에 BM 있으면 거기서 가져옴
  const bmFromLibrary = library.filter(x => x.id && x.id.startsWith('BM'));
  if (bmFromLibrary.length === 0) {
    statusEl.innerHTML = '⚠ 시트에 누적된 BM 광고 없음. 먼저 Apify 검색 실행 후 시트 저장하세요.';
    return;
  }
  benchmarkResults = bmFromLibrary.map(x => ({
    adId: x.metaAdId || '',
    pageName: x.pageName || '-',
    pageFollowers: x.followers || 0,
    bodyExcerpt: x.headline || '-',
    body: x.headline || '',
    displayFormat: x.format || '-',
    cta: x.cta || '-',
    startDate: x.startDate || '-',
    days: x.days || 0,
    platforms: x.platforms || [],
    collation: x.collation || 1,
    score: x.score || 0,
    grade: x.grade || '평가 보류',
    thumbnail: x.thumbnail || '',
    adLibraryUrl: x.adLibraryUrl || ''
  }));
  statusEl.innerHTML = `✅ 시트 누적 ${benchmarkResults.length}건 로드`;
  renderBenchmarkResults();
  renderBenchmarkAnalysis();
}

function renderBenchmarkResults() {
  const container = document.getElementById('bm-results');
  document.getElementById('bm-result-count').textContent = benchmarkResults.length;
  if (benchmarkResults.length === 0) {
    container.innerHTML = '<div class="info-box">결과 없음</div>';
    return;
  }
  container.innerHTML = benchmarkResults.map((r, i) => {
    const isSel = benchmarkSelected.has(i);
    const gradeColor = r.grade.startsWith('★★★') ? '#1b5e20' : r.grade.startsWith('★★') ? '#5d4e00' : r.grade.startsWith('★') ? '#01579b' : '#9e9e9e';
    const gradeBg = r.grade.startsWith('★★★') ? '#c8e6c9' : r.grade.startsWith('★★') ? '#fff9c4' : r.grade.startsWith('★') ? '#e1f5fe' : '#f5f5f5';
    const thumb = r.thumbnail ? `<img src="${escapeAttr(r.thumbnail)}" style="width:80px; height:80px; object-fit:cover; border-radius:6px; flex-shrink:0">` : '<div style="width:80px; height:80px; background:#eee; border-radius:6px; flex-shrink:0"></div>';
    return `
      <div onclick="toggleBenchmark(${i})" style="padding:10px; border:1px solid ${isSel ? '#007aff' : '#e0e0e0'}; background:${isSel ? '#e3f2fd' : '#fff'}; border-radius:8px; cursor:pointer; display:flex; gap:10px">
        <input type="checkbox" ${isSel ? 'checked' : ''} onchange="toggleBenchmark(${i})" onclick="event.stopPropagation()" style="margin-top:5px; width:18px; height:18px">
        ${thumb}
        <div style="flex:1; min-width:0">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:6px; margin-bottom:4px; flex-wrap:wrap">
            <strong style="font-size:13px">${escapeHtml(r.pageName)}</strong>
            <span style="font-size:10px; background:${gradeBg}; color:${gradeColor}; padding:2px 6px; border-radius:3px; font-weight:600">${escapeHtml(r.grade)}</span>
          </div>
          <div style="font-size:11px; color:#86868b; margin-bottom:4px">
            📅 ${r.days}일 운영 · 📍 ${(r.platforms || []).join('+')} · 🔁 변형 ${r.collation}개 · 👥 팔로워 ${r.pageFollowers} · 📹 ${r.displayFormat} · CTA: ${escapeHtml(r.cta)}
          </div>
          <div style="font-size:12px; color:#424245; max-height:60px; overflow:hidden; line-height:1.4">${escapeHtml(r.bodyExcerpt || '').replace(/\\n/g, ' ').slice(0, 300)}</div>
          <div style="margin-top:6px; display:flex; gap:6px">
            ${r.adLibraryUrl ? `<a href="${escapeAttr(r.adLibraryUrl)}" target="_blank" onclick="event.stopPropagation()" style="font-size:10px; color:#007aff">→ Ad Library 원문</a>` : ''}
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function escapeHtml(s) {
  return String(s || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function escapeAttr(s) { return escapeHtml(s); }

function toggleBenchmark(i) {
  if (benchmarkSelected.has(i)) benchmarkSelected.delete(i);
  else benchmarkSelected.add(i);
  renderBenchmarkResults();
}

function bmSelectAll(on) {
  benchmarkSelected.clear();
  if (on) benchmarkResults.forEach((_, i) => benchmarkSelected.add(i));
  renderBenchmarkResults();
}

function saveBenchmarkSelected() {
  if (benchmarkSelected.size === 0) { alert('선택된 광고 없음'); return; }
  if (!isAppsScriptWebApp()) { alert('Web App 환경 필요'); return; }
  const keyword = document.getElementById('bm-keyword').value.trim() || 'manual';
  const selected = Array.from(benchmarkSelected).map(i => benchmarkResults[i]);
  const statusEl = document.getElementById('bm-status');
  statusEl.innerHTML = `⏳ ${selected.length}건 시트 저장 중...`;
  google.script.run
    .withSuccessHandler(function(res) {
      if (res && res.ok) {
        statusEl.innerHTML = `✅ ${res.added}건 시트 저장 (★★★ ${res.goodCount}건)`;
        showToast(`💾 ${res.added}건 벤치마크 저장됨`);
        benchmarkSelected.clear();
        renderBenchmarkResults();
      } else {
        statusEl.innerHTML = `❌ ${res?.error || '저장 실패'}`;
      }
    })
    .withFailureHandler(err => statusEl.innerHTML = `❌ ${err.message || err}`)
    .saveBenchmarkSelectedFromGenerator(selected, keyword);
}

function renderBenchmarkAnalysis() {
  const target = benchmarkSelected.size > 0
    ? Array.from(benchmarkSelected).map(i => benchmarkResults[i])
    : benchmarkResults;
  const el = document.getElementById('bm-analysis');
  if (target.length === 0) { el.innerHTML = '<div style="color:#86868b">분석할 결과 없음</div>'; return; }
  // 통계
  const formatStats = {}, ctaStats = {}, platformStats = {}, pageStats = {};
  let daysSum = 0, daysCount = 0, collationSum = 0;
  const verified = []; // ★★★
  for (const r of target) {
    formatStats[r.displayFormat] = (formatStats[r.displayFormat] || 0) + 1;
    ctaStats[r.cta] = (ctaStats[r.cta] || 0) + 1;
    (r.platforms || []).forEach(p => platformStats[p] = (platformStats[p] || 0) + 1);
    pageStats[r.pageName] = (pageStats[r.pageName] || 0) + 1;
    if (r.days) { daysSum += r.days; daysCount++; }
    collationSum += (r.collation || 1);
    if (r.grade.startsWith('★★★')) verified.push(r);
  }
  // 후킹 키워드 — 본문 첫 줄 추출
  const hookFreq = {};
  target.forEach(r => {
    const first = (r.bodyExcerpt || '').split('|')[0].split('\n')[0].trim();
    const words = first.split(/[\s,!?.]+/).filter(w => w.length >= 2 && !/^[␀-]+$/.test(w));
    words.slice(0, 3).forEach(w => hookFreq[w] = (hookFreq[w] || 0) + 1);
  });
  const topHooks = Object.entries(hookFreq).sort((a, b) => b[1] - a[1]).slice(0, 8);

  function row(title, stats) {
    const sorted = Object.entries(stats).sort((a, b) => b[1] - a[1]);
    return `<div style="margin-bottom:8px"><strong style="font-size:11px">${title}</strong><div style="font-size:11px; color:#424245">${sorted.map(([k, v]) => `${escapeHtml(k)} ×${v}`).join(' · ') || '-'}</div></div>`;
  }
  el.innerHTML = `
    <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:10px">
      <div>${row('📹 광고 형식', formatStats)}</div>
      <div>${row('🎯 CTA', ctaStats)}</div>
      <div>${row('📍 노출 채널', platformStats)}</div>
      <div>${row('🏢 페이지별', pageStats)}</div>
    </div>
    <div style="margin-top:10px; padding-top:10px; border-top:1px solid #eee">
      <strong style="font-size:11px">📊 핵심 지표</strong>
      <div style="font-size:11px; color:#424245">
        총 ${target.length}건 · 평균 운영 ${daysCount > 0 ? Math.round(daysSum/daysCount) : 0}일 · 평균 변형 ${(collationSum/target.length).toFixed(1)}개 · ★★★ ${verified.length}건
      </div>
    </div>
    <div style="margin-top:10px">
      <strong style="font-size:11px">🔥 후킹 키워드 빈도 (본문 첫 줄)</strong>
      <div style="font-size:11px; color:#424245">${topHooks.map(([w, c]) => `${escapeHtml(w)} ×${c}`).join(' · ') || '-'}</div>
    </div>
  `;
}

// ============ 옵션 C 폐기 (2026-06-09) ============
// 컨셉 태그 시트·동적 폼 시스템 종민 결정으로 전체 제거.
// 신규 컨셉은 카피 입력 폼의 "🆕 신규 컨셉 (자유 입력)" 한 줄로 처리.

// ============ 카피 입력 수집 ============
function getCopyContext() {
  const tones = Array.from(document.querySelectorAll('#c-tones input:checked')).map(el => el.value);
  return {
    category: document.getElementById('c-category').value,
    age: document.getElementById('c-age').value,
    gender: document.getElementById('c-gender').value,
    season: document.getElementById('c-season').value,
    product: document.getElementById('c-product').value || '내 휴대폰',
    usp: document.getElementById('c-usp').value || '가격 조회',
    emotion: document.getElementById('c-emotion').value,
    keywords: document.getElementById('c-keywords').value,
    length: document.getElementById('c-length').value,
    tones: tones.length > 0 ? tones : ['감성/부드러움', '직설/강력'],
    newConcept: (document.getElementById('c-new-concept')?.value || '').trim()  // 🆕 자유 입력 신규 컨셉
  };
}

// ============ 카피 폼 랜덤 채우기 ============
function randomFillCopy(thenGenerate) {
  setSelectValue('c-category', pick(RANDOM_POOLS.category));
  setSelectValue('c-age', pick(RANDOM_POOLS.age));
  setSelectValue('c-gender', pick(RANDOM_POOLS.gender));
  setSelectValue('c-season', pick(RANDOM_POOLS.season));
  document.getElementById('c-product').value = pick(RANDOM_POOLS.product);
  document.getElementById('c-usp').value = pick(RANDOM_POOLS.usp);
  setSelectValue('c-emotion', pick(RANDOM_POOLS.emotion));
  document.getElementById('c-keywords').value = pick(RANDOM_POOLS.keywords);
  setSelectValue('c-length', pick(RANDOM_POOLS.length));
  setCheckboxGroup('c-tones', pickSubset(RANDOM_POOLS.copyTones, 1, 3));
  showToast('카피 폼 랜덤 채움');
  if (thenGenerate) {
    generateCopiesFromLibrary();
  }
}

// ============ 🧹 전체 초기화 ============
function resetAllForm() {
  setSelectValue('c-category', '휴대폰 판매');
  setSelectValue('c-age', '전 연령');
  setSelectValue('c-gender', '전체');
  setSelectValue('c-season', '시즌리스');
  document.getElementById('c-product').value = '';
  document.getElementById('c-usp').value = '';
  setSelectValue('c-emotion', '자유');
  document.getElementById('c-keywords').value = '';
  setSelectValue('c-length', '자유');
  setCheckboxGroup('c-tones', []);
  const nc = document.getElementById('c-new-concept');
  if (nc) nc.value = '';
  // 카피 결과도 비우기
  currentCopies = [];
  selectedCopies.clear();
  const resultsSection = document.getElementById('copy-results-section');
  if (resultsSection) resultsSection.classList.add('hidden');
  showToast('🧹 폼 + 카피 결과 전체 초기화');
}

// ============ 📚 라이브러리 + 벤치마크 기반 생성 (즉시) ============
// 메타 우수 광고 패턴 + 60+ 검증 템플릿 풀에서 20개 추출
// 벤치마크 apify 크롤링: 구현 예정 (현재는 메타 라이브러리만 사용)
function generateCopiesFromLibrary() {
  const ctx = getCopyContext();
  // 신규 컨셉이 박혀 있으면 경고 (이 모드는 자유 텍스트 반영 X)
  if (ctx.newConcept) {
    showToast(`⚠️ 신규 컨셉 "${ctx.newConcept}"은 이 모드에서 반영 ❌. 🤖 LLM 프롬프트 버튼 사용 권장.`);
  }
  currentCopies = generateCopiesTemplate(ctx);
  renderCopies();
  // 자동 주입 알림
  if (ctx._autoKeywordsInjected) {
    showToast(`📡 라이브러리 우수 키워드 자동 적용: ${ctx._autoKeywordsInjected}`);
  } else {
    const verifiedCount = currentCopies.filter(c => c.isVerified).length;
    if (verifiedCount > 0) {
      showToast(`✨ 검증된 메타 카피 ${verifiedCount}개 포함`);
    }
  }
}

// ============ 🤖 LLM 프롬프트 생성 (Claude/GPT 챗용) ============
function generateCopiesViaLLM() {
  const ctx = getCopyContext();
  const prompt = buildCopyPrompt(ctx);
  copyText(prompt);
  const conceptMsg = ctx.newConcept ? ` (신규 컨셉 "${ctx.newConcept}" 박힘)` : '';
  showToast(`🤖 LLM 프롬프트 복사됨${conceptMsg}. Claude/GPT 챗에 붙여넣기.`);
}

// 하위 호환: 옛 호출(generateCopies)이 남아있을 경우 라이브러리 모드로 폴백
function generateCopies() { generateCopiesFromLibrary(); }

// 라이브러리 메타 우수 광고 인사이트 추출
function getMetaLibraryInsights() {
  const metaItems = library.filter(x => x.metaAdId);
  const good = metaItems.filter(x => x.performance?.evaluation === '우수');
  // 키워드 빈출 추출 (2글자 이상)
  const keywordFreq = {};
  good.forEach(x => {
    const words = (x.headline || '').split(/[\s,?.!]+/).filter(w => w.length >= 2);
    words.forEach(w => { keywordFreq[w] = (keywordFreq[w] || 0) + 1; });
  });
  const topKeywords = Object.entries(keywordFreq)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 10)
    .map(([w]) => w);
  // 패턴 빈도
  const patternFreq = {};
  good.forEach(x => {
    if (x.pattern) patternFreq[x.pattern] = (patternFreq[x.pattern] || 0) + 1;
  });
  // 검증된 헤드라인 (그대로 카피 후보로)
  const verifiedHeadlines = good.map(x => ({
    pattern: '✨ 검증된 메타 광고',
    text: x.headline,
    chars: (x.headline || '').replace(/\s/g, '').length,
    metaAdId: x.metaAdId,
    ctr: x.performance?.ctr,
    isVerified: true
  })).filter(x => x.text && x.text !== '-');
  return { good, topKeywords, patternFreq, verifiedHeadlines };
}

function generateCopiesTemplate(ctx) {
  // ★ 0. 라이브러리 우수 광고 인사이트 추출
  const insights = getMetaLibraryInsights();
  const hasInsights = insights.good.length > 0;

  // ★ 1. 추가 키워드가 비어있고 라이브러리에 우수 광고 있으면 → 자동 주입
  if ((!ctx.keywords || !ctx.keywords.trim()) && insights.topKeywords.length > 0) {
    ctx.keywords = insights.topKeywords.slice(0, 3).join(', ');
    ctx._autoKeywordsInjected = ctx.keywords;
  }

  // 2. 키워드 슬롯 필요한 패턴은 키워드 입력 없을 때 제외
  let pool = CATALOG.copyPatterns.filter(p => {
    if (p.template.includes('{키워드}')) {
      const list = (ctx.keywords || '').split(',').map(s => s.trim()).filter(Boolean);
      return list.length > 0;
    }
    return true;
  });

  // 3. 감정 매칭 가중치
  if (ctx.emotion && ctx.emotion !== '자유') {
    const weighted = [];
    pool.forEach(p => {
      const matched = PATTERN_EMOTION[p.name]?.includes(ctx.emotion);
      const weight = matched ? 3 : 1;
      for (let i = 0; i < weight; i++) weighted.push(p);
    });
    pool = weighted;
  }

  // ★ 4. 라이브러리 우수 패턴 추가 가중치 (메타에서 잘됐던 패턴 ×2)
  if (hasInsights && Object.keys(insights.patternFreq).length > 0) {
    const weighted = [];
    pool.forEach(p => {
      const libBoost = insights.patternFreq[p.name] ? 2 : 1;
      for (let i = 0; i < libBoost; i++) weighted.push(p);
    });
    pool = weighted;
  }

  // ★ 5. 검증된 헤드라인 일부를 카피 풀에 직접 포함 (최대 5개, 셔플)
  const verifiedToInclude = shuffle(insights.verifiedHeadlines).slice(0, Math.min(5, insights.verifiedHeadlines.length));
  const templateCount = Math.max(15, 20 - verifiedToInclude.length);

  // 6. 셔플 + 중복 제거 + 템플릿 카피 N개 픽
  const shuffled = shuffle(pool);
  const seen = new Set();
  const picked = [];
  for (const p of shuffled) {
    if (seen.has(p.template)) continue;
    seen.add(p.template);
    picked.push(p);
    if (picked.length >= templateCount) break;
  }

  // 7. 템플릿 카피 생성
  const templateCopies = picked.map(p => {
    const text = fillSlots(p.template, ctx);
    return { pattern: p.name, text, chars: text.replace(/\s/g, '').length };
  });

  // 8. 검증 카피 + 템플릿 카피 합치고 셔플
  return shuffle([...verifiedToInclude, ...templateCopies]);
}

function buildCopyPrompt(ctx, count = 25) {
  const conceptBlock = ctx.newConcept
    ? `[🆕 신규 컨셉 — 사람(종민)이 지정한 핵심 키워드. 카피 절반(${Math.round(count*0.5)}개)에 자연스럽게 반영. 단순 단어 박기 ❌, 문맥 활용 ✅]\n${ctx.newConcept}\n\n`
    : '';

  // 자체 광고 우수 사례 (CTR 7%+)
  const goodExamples = (library || [])
    .filter(x => x.performance && x.performance.evaluation === '우수' && x.headline && x.headline !== '-' && x.headline.length < 40)
    .sort((a, b) => (parseFloat(b.performance.ctr) || 0) - (parseFloat(a.performance.ctr) || 0))
    .slice(0, 5)
    .map(x => `- "${x.headline}" (CTR ${x.performance.ctr}%)`);
  const examplesBlock = goodExamples.length > 0
    ? `\n[★ 자체 라이브러리 우수 사례 — 폰스팟 메타 CTR 7%+ 검증 카피. 톤·구조·길이감 학습용, 복제 ❌]\n${goodExamples.join('\n')}\n`
    : '';

  // 🎯 벤치마크 우수 사례 (BM-XXX, 90일+ 운영 = ★★★ 검증)
  const bmAds = (library || []).filter(x => x.id && x.id.startsWith('BM') && x.headline && x.headline !== '-');
  const bmGood = bmAds.filter(x => (x.days || 0) >= 90 || (x.score || 0) >= 5).slice(0, 5);
  const bmHookFreq = {};
  bmAds.forEach(x => {
    const first = (x.headline || '').split('|')[0].split('\n')[0].trim();
    const words = first.split(/[\s,!?.]+/).filter(w => w.length >= 2);
    words.slice(0, 2).forEach(w => bmHookFreq[w] = (bmHookFreq[w] || 0) + 1);
  });
  const topBmHooks = Object.entries(bmHookFreq).sort((a, b) => b[1] - a[1]).slice(0, 6);
  const bmBlock = bmGood.length > 0 ? `
[🎯 벤치마크 — 경쟁사 메타 광고 라이브러리 검증된 후킹. 90일+ 운영 = 실제로 잘 굴러간 광고]
${bmGood.map(x => `- [${x.pageName || '-'}] "${(x.headline || '').slice(0, 100).replace(/\n/g, ' ')}" (${x.days}일 운영, 변형 ${x.collation || 1}개)`).join('\n')}
${topBmHooks.length > 0 ? `\n경쟁사 본문 첫 줄 빈출 후킹 단어: ${topBmHooks.map(([w, c]) => `${w}(×${c})`).join(', ')}` : ''}
※ 폰스팟 본질(즉시 가격 확인 + 호기심 갭)을 우선. 벤치마크는 후킹 다양화 학습용, 그대로 복제 ❌. 경쟁사 톤(긴 본문/스토리/매장방문 유도)과 폰스팟 톤(짧고 즉시클릭) 구분 유지.
` : '';

  // 패턴 풀 60+ → 무작위 8개만 발췌 (GPT가 패턴 이름 채우기에 집중하지 않게)
  const patternSample = shuffle(CATALOG.copyPatterns).slice(0, 8)
    .map(p => `- ${p.name}: 예) ${p.template}`).join('\n');

  // 길이 분포 정확히 분배 (count = 25 기준: 5/7/8/5)
  const dist = {
    short: Math.round(count * 0.20),   // 5개
    mid:   Math.round(count * 0.28),   // 7개
    long:  Math.round(count * 0.32),   // 8개
    xlong: count - Math.round(count * 0.20) - Math.round(count * 0.28) - Math.round(count * 0.32) // 5개
  };

  return `당신은 폰스팟(citymarket.co.kr/pb)의 한국어 광고 헤드라인 카피라이터입니다. ${count}개를 만들어주세요.

${conceptBlock}[브랜드 본질 — 카피의 핵심 메시지에 반드시 녹일 것]
폰스팟의 차별점:
1. "회원가입·로그인·상담 없이" 즉시 가격 확인 — 비교·문의·매장 방문 없이 1초 만에 내 가격 조회
2. 호기심 갭(궁금 → 클릭) 유도 — "얼마인지 보고 싶다"는 충동을 일으키는 게 카피의 1순위
3. 가격 자체는 명시 ❌. "확인하면 놀랄 만큼 싼 가격"이라는 암시만
4. 대조 구도가 강력: 옛 방식(전화 문의/매장 방문/긴 상담) ↔ 폰스팟(클릭 1번/즉시 확인/투명)
5. 톤은 거품 빼고 직설적이거나, 친근하게 옆자리 동료처럼 (꼰대·과장·이모지 남발 X)

[조건 — GPT는 이 값들을 단순 조합하지 말고 자연스러운 한국어 문장으로 녹일 것]
- 타겟: ${ctx.age} ${ctx.gender}
- 시즌: ${ctx.season}
- 제품: ${ctx.product}
- 핵심 USP: ${ctx.usp}
- 강조 감정: ${ctx.emotion}
- 톤: ${ctx.tones.join(', ')}
- 추가 키워드: ${ctx.keywords || '없음'}
- 길이 선호: ${ctx.length}
${examplesBlock}${bmBlock}
[엄격 규칙 — 위반 시 카피 폐기·재생성]
1. **단어 반복 금지**: 같은 명사·동사·형용사가 ${count}개 카피 중 **3회 초과 등장 ❌**. (예: "재고확인"이 13/24 등장 = 위반. 최대 3개까지)
2. **길이 분포 강제**: 총 ${count}개를 정확히 다음 비율로:
   - 8자 이내 (짧고 강렬) × ${dist.short}개
   - 9-14자 (중간, 모바일 최적) × ${dist.mid}개
   - 15-20자 (정보 1개 + 후킹) × ${dist.long}개
   - 21자 이상 (스토리·반전·문장형) × ${dist.xlong}개
3. **단순 단어 조합 금지**: "X 재고확인" / "X 직장인 픽" / "X점 Y확인" 같은 명사 나열 ❌. 자연스러운 한국어 문장·의문형·감탄형 우선.
4. **가격 명시 금지**: 만원/원/숫자가격 표기 ❌. "최대 X만원" "X% 할인" 같은 표현도 ❌.
5. **인물 묘사 금지**: 사람 외형·이름 ❌. 제품·서비스·상황 중심.
6. **반복형 패턴 피하기**: 같은 의문 구조("X 안 봐요?"/"X 알아요?") 3개 이상 ❌.
${ctx.newConcept ? `7. **신규 컨셉 "${ctx.newConcept}"은 ${Math.round(count*0.5)}개 정도에만 자연스럽게 반영**. 모든 카피에 박지 말 것 — 다른 카피는 폰스팟 본질로.\n` : ''}
[다양화 패턴 풀 — 8개만 발췌 (전체 60+ 중). 참고만 하고 자유 변형 OK. 패턴 이름 채우기에 집중 ❌, 카피 자체에 집중 ✅]
${patternSample}

[출력 형식 — 마크다운 표만, JSON·코드블록 ❌, 다른 설명 ❌]
| 번호 | 헤드라인 | 글자수 | 길이층 | 패턴 메모 |
|------|----------|--------|--------|-----------|
| 1 | (헤드라인) | (공백제외 글자수) | 8자/9-14/15-20/21+ 중 하나 | (자유, 한 줄 메모) |
| 2 | ... | ... | ... | ... |
... (${count}개 모두 채울 것)

[표 다음 마지막 줄에 자가검증 — 형식 그대로]
✅ 검증
- 총 ${count}개 작성 확인
- 길이 분포: 8자 ×N / 9-14 ×N / 15-20 ×N / 21+ ×N (목표: ${dist.short}/${dist.mid}/${dist.long}/${dist.xlong})
- 최다 반복 명사·동사: "(단어)" ×N회 (룰: 3회 이하)
${ctx.newConcept ? `- 신규 컨셉 "${ctx.newConcept}" 반영: N/${count} (목표: ${Math.round(count*0.5)}±2)` : ''}`;
}

function renderCopies() {
  document.getElementById('copy-results-section').classList.remove('hidden');
  document.getElementById('copy-count').textContent = currentCopies.length;
  selectedCopies.clear();
  updateSelectedCount('copy');
  const container = document.getElementById('copy-results');
  if (currentCopies.length === 0) {
    container.innerHTML = '<div class="info-box">생성된 카피가 없습니다</div>';
    return;
  }
  // D3: 라이브러리에 이미 있는 슬로건인지 체크
  const libraryHeadlines = new Set(library.map(x => (x.headline || '').trim()));
  container.innerHTML = currentCopies.map((c, i) => {
    const inLibrary = libraryHeadlines.has((c.text || '').trim());
    let badge = '';
    if (c.isVerified) badge = '<span style="font-size:10px; background:#4caf50; color:#fff; padding:2px 5px; border-radius:3px; margin-right:4px">✨ 검증</span>';
    else if (inLibrary) badge = '<span style="font-size:10px; background:#ff9800; color:#fff; padding:2px 5px; border-radius:3px; margin-right:4px">🔄 운영중</span>';
    else badge = '<span style="font-size:10px; background:#9e9e9e; color:#fff; padding:2px 5px; border-radius:3px; margin-right:4px">🆕 신규</span>';
    return `
      <div class="candidate ${selectedCopies.has(i) ? 'selected' : ''}" style="${c.isVerified ? 'border-left:3px solid #4caf50; background:#f1f8e9;' : (inLibrary ? 'border-left:3px solid #ff9800;' : '')}" onclick="toggleCopy(${i})">
        <div class="candidate-header">
          <span>${badge}<span class="pattern-tag" style="${c.isVerified ? 'background:#4caf50; color:#fff' : ''}">${c.pattern || '-'}</span></span>
          <span style="display:flex; gap:6px; align-items:center">
            ${c.ctr ? `<span class="candidate-meta" style="color:#2e7d32; font-weight:600">CTR ${c.ctr}%</span>` : ''}
            <span class="candidate-meta">${c.chars}자</span>
            <button class="small secondary" onclick="event.stopPropagation(); copySloganByIndex(${i})" title="슬로건 변형 20개 프롬프트 복사">📋 슬로건</button>
            <button class="small" onclick="event.stopPropagation(); copyImagePromptForCopy(${i})" title="이 슬로건으로 이미지 프롬프트 생성·복사">🎨 이미지</button>
          </span>
        </div>
        <div class="candidate-text">${c.text}</div>
      </div>
    `;
  }).join('');
}

function toggleCopy(i) {
  if (selectedCopies.has(i)) selectedCopies.delete(i);
  else selectedCopies.add(i);
  document.querySelectorAll('#copy-results .candidate')[i].classList.toggle('selected');
  updateSelectedCount('copy');
}

function copySelectedCopies() {
  const copies = Array.from(selectedCopies).map(i => currentCopies[i]);
  if (copies.length === 0) { alert('선택된 카피 없음'); return; }
  copyText(copies.map((c, i) => `${i + 1}. [${c.pattern}] ${c.text}`).join('\n'));
}

function setActiveCopies() {
  const copies = Array.from(selectedCopies).map(i => currentCopies[i]);
  if (copies.length === 0) { alert('선택된 카피 없음'); return; }
  activeCopies = copies;
  renderActive();
  showToast(`${copies.length}개 카피를 라이브러리용으로 설정`);
}

// ============ 슬로건 변형 20개 프롬프트 복사 ============
function buildSloganVariationPrompt(referenceSlogan, referencePattern, ctx) {
  const conceptBlock = ctx.newConcept
    ? `[🆕 신규 컨셉 — 절반(10개)에 자연스럽게 반영. 모든 변형에 박지 말 것]\n${ctx.newConcept}\n\n`
    : '';
  const refLen = (referenceSlogan || '').replace(/\s/g, '').length;
  return `당신은 폰스팟(citymarket.co.kr/pb)의 한국어 광고 슬로건 카피라이터입니다. 슬로건 변형 20개를 만들어주세요.

[참고 슬로건]
"${referenceSlogan}" (${refLen}자)

[패턴]
${referencePattern || '미정'}

${conceptBlock}[브랜드 본질 — 변형의 핵심 메시지에 녹일 것]
폰스팟의 차별점:
1. "회원가입·로그인·상담 없이" 즉시 가격 확인 — 1초 만에 내 가격 조회
2. 호기심 갭(궁금 → 클릭) 유도가 슬로건의 1순위
3. 가격 자체 명시 ❌. "확인하면 놀랄 만큼 싼 가격" 암시만
4. 옛 방식(전화 문의/매장 방문/긴 상담) ↔ 폰스팟(클릭 1번/즉시 확인) 대조 효과적
5. 거품 빼고 직설 또는 친근한 톤 (꼰대·과장·이모지 남발 ❌)

[캠페인 컨텍스트]
- 타겟: ${ctx.age || '전 연령'} ${ctx.gender || '전체'}
- 시즌: ${ctx.season || '시즌리스'}
- 제품: ${ctx.product || '미정'}
- 핵심 USP: ${ctx.usp || '미정'}
- 강조 감정: ${ctx.emotion || '자유'}
- 톤 선호: ${(ctx.tones || []).join(', ') || '자유'}
- 추가 키워드: ${ctx.keywords || '없음'}

[엄격 규칙 — 위반 시 변형 폐기·재생성]
1. **참고 슬로건의 패턴·골격·길이감 유지**, 표현·단어·뉘앙스·후크는 다양화. A/B 테스트 가능한 수준.
2. **단어 반복**: 같은 명사·동사가 20개 중 3회 초과 등장 ❌.
3. **길이 분포**: 참고 ${refLen}자 기준 ±5자 범위에서 분산. 모든 변형이 같은 길이 ❌.
4. **단순 단어 치환 ❌**: 명사 1개만 바꿔치기한 변형은 1~2개만. 나머지는 구조·후킹·시제 변형.
5. **가격 명시 ❌**: 만원/원/숫자가격 ❌.
6. **인물 묘사 ❌**: 사람 외형·이름 ❌. 제품·서비스·상황 중심.

[출력 형식 — 표만, 다른 설명 ❌]
| 번호 | 슬로건 | 글자수 | 변형 포인트 |
| 1 | (슬로건) | (숫자) | (예: 후킹 강화 / 시제 변경 / 부정형 전환) |
| 2 | ... | ... | ... |
...
| 20 | ... | ... | ... |`;
}

function copySloganByIndex(i) {
  if (!currentCopies[i]) return;
  const c = currentCopies[i];
  const ctx = getCopyContext();
  const prompt = buildSloganVariationPrompt(c.text, c.pattern, ctx);
  copyText(prompt);
  showToast('슬로건 변형 20개 프롬프트 복사됨. Claude/GPT 챗에 붙여넣기');
}

// ============ 카피 → 이미지 프롬프트 자동 생성·복사 ============
function copyImagePromptForCopy(copyIndex) {
  const copy = currentCopies[copyIndex];
  if (!copy) return;
  const cCtx = getCopyContext();
  const visualToneKey = deriveVisualTone(cCtx, copy);
  const tone = CATALOG.tones[visualToneKey];
  const layout = pick(tone.layouts);
  // 카피 폼의 모든 입력 조건을 ctx에 통째로 전달
  const ctx = {
    ...cCtx,
    headline: copy.text,
    pattern: copy.pattern || ''
  };
  const prompt = buildImagePrompt(ctx, tone, layout);
  copyText(prompt);
  showToast(`이미지 프롬프트 복사됨 (${copy.pattern} → ${tone.label}, ${layout})`);
}

function deriveVisualTone(cCtx, copy) {
  // 우선순위 1: 카피 패턴이 강한 시각적 함의를 가짐 → 패턴 매핑 사용
  if (copy && copy.pattern && CATALOG.patternToTone[copy.pattern]) {
    return CATALOG.patternToTone[copy.pattern];
  }
  // 우선순위 2: 시즌 (시즌 톤이 카피와 충돌하지 않을 때)
  const seasonalMap = {
    '봄': '감성_봄',
    '여름': '시즌_여름',
    '가을': '시즌_가을',
    '겨울': '시즌_겨울',
    '크리스마스': '시즌_겨울'
  };
  if (seasonalMap[cCtx.season]) return seasonalMap[cCtx.season];
  // 우선순위 3: 카피 폼의 톤 선호
  const copyToneMap = {
    '감성/부드러움': '감성_봄',
    '직설/강력': '직설_강력',
    '유머/B급': '유머_B급',
    '정보성/신뢰': '정보_신뢰',
    '미니멀/프리미엄': '미니멀_프리미엄'
  };
  const mappedTones = (cCtx.tones || []).map(t => copyToneMap[t]).filter(Boolean);
  return mappedTones.length > 0 ? pick(mappedTones) : '직설_강력';
}

// ============ 라이브러리 우수 광고 디자인 분석 ============
// 광고명에 박힌 색상·스타일 키워드 자동 추출 + 광고명별 CTR 통계
function analyzeWinningDesigns_() {
  const winners = (library || [])
    .filter(x => x.performance && x.performance.evaluation === '우수'
      && x.headline && x.headline !== '-'
      && parseFloat(x.performance.ctr) >= 7);
  if (winners.length === 0) return null;

  // 색상·스타일 키워드 사전 (한글 + 영문)
  const styleVocab = {
    colors: { '초록':'green', '파랑':'blue', '빨강':'red', '분홍':'pink', '핑크':'pink',
              '노랑':'yellow', '검정':'black', '흰색':'white', '주황':'orange',
              '보라':'purple', '마젠타':'magenta', '하늘':'sky blue', '회색':'gray' },
    styles: { '미니멀':'minimalist', '홀로그램':'holographic', '신문':'newspaper layout',
              '콜라주':'collage', '플랫폼':'flat platform', '신문':'editorial' }
  };

  // 광고명에서 키워드 추출
  const colorStats = {}; // {color: {count, ctrSum}}
  const styleStats = {};
  for (const ad of winners) {
    const name = String(ad.name || '');
    const ctr = parseFloat(ad.performance.ctr) || 0;
    for (const [kr, en] of Object.entries(styleVocab.colors)) {
      if (name.includes(kr)) {
        if (!colorStats[en]) colorStats[en] = { count: 0, ctrSum: 0, kr: kr };
        colorStats[en].count++;
        colorStats[en].ctrSum += ctr;
      }
    }
    for (const [kr, en] of Object.entries(styleVocab.styles)) {
      if (name.includes(kr)) {
        if (!styleStats[en]) styleStats[en] = { count: 0, ctrSum: 0, kr: kr };
        styleStats[en].count++;
        styleStats[en].ctrSum += ctr;
      }
    }
  }
  // 색상별 평균 CTR 정렬
  const colorRank = Object.entries(colorStats)
    .map(([en, s]) => ({ en, kr: s.kr, count: s.count, avgCtr: (s.ctrSum / s.count).toFixed(2) }))
    .sort((a, b) => parseFloat(b.avgCtr) - parseFloat(a.avgCtr));
  const styleRank = Object.entries(styleStats)
    .map(([en, s]) => ({ en, kr: s.kr, count: s.count, avgCtr: (s.ctrSum / s.count).toFixed(2) }))
    .sort((a, b) => parseFloat(b.avgCtr) - parseFloat(a.avgCtr));

  // 상위 5개 광고 (CTR 기준)
  const top5 = winners
    .sort((a, b) => (parseFloat(b.performance.ctr) || 0) - (parseFloat(a.performance.ctr) || 0))
    .slice(0, 5)
    .map(x => ({
      name: x.name || '-',
      headline: x.headline,
      ctr: x.performance.ctr,
      spend: x.performance.spend || 0
    }));

  return { colorRank, styleRank, top5, totalWinners: winners.length };
}

// 🎯 벤치마크 디자인 코드 분석
function buildBenchmarkDesignBlock_() {
  const bm = (library || []).filter(x => x.id && x.id.startsWith('BM'));
  const verified = bm.filter(x => (x.days || 0) >= 90 || (x.score || 0) >= 5);
  if (verified.length === 0) return '';
  // 광고 형식 분포
  const formatStats = {}, ctaStats = {};
  verified.forEach(x => {
    formatStats[x.format || '-'] = (formatStats[x.format || '-'] || 0) + 1;
    ctaStats[x.cta || '-'] = (ctaStats[x.cta || '-'] || 0) + 1;
  });
  const fmtSorted = Object.entries(formatStats).sort((a, b) => b[1] - a[1]);
  const ctaSorted = Object.entries(ctaStats).sort((a, b) => b[1] - a[1]);
  return `
[🎯 Benchmark design code — Competitor verified ads (90d+ run on Meta Ad Library)]
Verified ads: ${verified.length} (out of ${bm.length} total benchmark)
- Display format distribution: ${fmtSorted.map(([k, v]) => `${k}(${v})`).join(', ')}
- CTA distribution: ${ctaSorted.map(([k, v]) => `${k}(${v})`).join(', ')}
Notes on competitor visual code:
- Competitor (e.g. 동탄 도매폰센타) tends to use VIDEO format with long Korean body text overlay; PhoneSpot uses STATIC IMAGE with short bold headline. Keep PhoneSpot visual DNA — don't adopt competitor's video-heavy style.
- Competitor CTA = Instagram profile redirect; PhoneSpot CTA = direct price check link. Visual should reinforce "click → instant price" affordance.
- Visual learning from benchmark: layout principles + Korean typography conventions only. Hook style and CTA stay PhoneSpot-distinct.
`;
}

// 디자인 분석 결과 → 영문 마크다운 블록
function buildLibraryDesignBlock_() {
  const analysis = analyzeWinningDesigns_();
  if (!analysis) return '';

  const lines = ['', '[★ Reference: PhoneSpot library winning ads — CTR 7%+ verified]',
    'Learn the design code (color, layout, typography, hook style) from these top performers. Apply principles, do NOT copy directly.', ''];

  // 상위 5개 광고 명시
  lines.push(`Top ${analysis.top5.length} winners (of ${analysis.totalWinners} verified):`);
  for (const t of analysis.top5) {
    lines.push(`- "${t.name}" → Headline: "${t.headline}" (CTR ${t.ctr}%, spend ${t.spend.toLocaleString()}원)`);
  }
  lines.push('');

  // 색상 분포
  if (analysis.colorRank.length > 0) {
    lines.push('Color performance ranking (from winning ad names):');
    for (const c of analysis.colorRank.slice(0, 5)) {
      lines.push(`- ${c.en} (${c.kr}): ${c.count} winners, avg CTR ${c.avgCtr}%`);
    }
    lines.push(`→ Strongest color: ${analysis.colorRank[0].en} (${analysis.colorRank[0].kr})`);
    lines.push('');
  }

  // 스타일 분포
  if (analysis.styleRank.length > 0) {
    lines.push('Style performance ranking:');
    for (const s of analysis.styleRank.slice(0, 5)) {
      lines.push(`- ${s.en} (${s.kr}): ${s.count} winners, avg CTR ${s.avgCtr}%`);
    }
    lines.push('');
  }

  // 디자인 코드 추론
  lines.push('Inferred design code from winners:');
  lines.push('- Hook style: question-based ("얼마일까?", "공짜?", "안보면 손해?") + imperative CTA ("확인해보세요", "터치 한 번")');
  lines.push('- Composition: Korean headline at top (bold sans-serif), product at center, clean color block background');
  lines.push('- Typography: heavy weight, high contrast against background, mobile-legible (≥80px equivalent)');
  lines.push('- Background: solid color block (top performers use ' +
    (analysis.colorRank[0] ? analysis.colorRank[0].en : 'vivid solid colors') + '), avoid noisy textures');
  lines.push('- No human figures, no prices, no excessive icons');
  lines.push('');
  lines.push('Apply these codes to the new banner. Headline messaging may differ but visual DNA should match the winners.');

  return lines.join('\n');
}

