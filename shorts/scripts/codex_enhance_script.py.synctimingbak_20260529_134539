# -*- coding: utf-8 -*-
import json
import re
import sys
from pathlib import Path

ROOT = Path(__file__).parent.parent.parent
CARDNEWS = ROOT / "cardnews"

CASUAL_REPLACEMENTS = [
    ("더하기", "와"),
    ("작동해요", "작동합니다"),
    ("가능해져요", "가능해집니다"),
    ("해드려요", "해드립니다"),
    ("켜둘 건", "켜둘 수 있는 건"),
    ("비번", "비밀번호"),
    ("익숙치", "익숙하지"),
    ("됐어요", "됐습니다"),
    ("나왔어요", "나왔습니다"),
    ("보도했어요", "보도했습니다"),
]

COMPLETE_ENDINGS = ("다.", "요.", "죠.", "까?", "니다.", "습니다.", "입니다.", "합니다.", "됩니다.", "라고 합니다.")
CONNECTOR_ENDINGS = ("고,", "되고,", "하며,", "되며,", "이면,", "지만,", "때문에,", "기준으로,")


def clean_text(text: str) -> str:
    return re.sub(r"\s+", " ", (text or "").strip())


def normalize_tts(text: str) -> str:
    out = clean_text(text)
    for old, new in CASUAL_REPLACEMENTS:
        out = out.replace(old, new)
    return clean_text(out)


def has_predicate(text: str) -> bool:
    s = text.strip()
    return s.endswith(COMPLETE_ENDINGS) or s.endswith(CONNECTOR_ENDINGS)


def sync_display_chunk(text: str, idx: int, total: int) -> str:
    """Keep the exact chunk meaning/order and only add light Korean grammar.

    The screen caption must feel synced with TTS. Do not add new concepts.
    """
    clean = normalize_tts(text)
    if not clean:
        return clean
    if has_predicate(clean):
        return clean

    is_last = idx == total - 1

    if not is_last:
        if clean.endswith(("전환", "연동", "적용", "공개", "개방", "인상", "잠금")):
            return clean + "되고,"
        if clean.endswith(("확인", "판단", "분석", "검토", "비교", "대응", "요구", "변경")):
            return clean + "하고,"
        if clean.endswith(("보도", "전망", "예정")):
            return clean + " 기준으로,"
        return clean + "이고,"

    if clean.endswith(("가능", "대응", "확인", "점검", "조회")):
        return clean + "할 수 있습니다."
    if clean.endswith(("전환", "연동", "적용", "공개", "개방", "인상", "잠금", "요구", "지연")):
        return clean + "됩니다."
    return clean + "입니다."


def make_display_chunks(chunks):
    return [sync_display_chunk(chunk, idx, len(chunks)) for idx, chunk in enumerate(chunks or [])]


def make_tts_from_chunks(chunks):
    """Codex sync rule: TTS follows caption_chunks, not a separate rewritten paragraph."""
    parts = [normalize_tts(chunk) for chunk in (chunks or []) if clean_text(chunk)]
    if not parts:
        return ""
    text = " ".join(parts)
    if not text.endswith((".", "?", "!")):
        text += "."
    return text


def process_section(section):
    chunks = section.get("caption_chunks") or []
    if chunks:
        section["tts"] = make_tts_from_chunks(chunks)
        section["display_chunks"] = make_display_chunks(chunks)
        section["_codex_sync_mode"] = "tts_caption_display_same_order"
    elif section.get("tts"):
        section["tts"] = normalize_tts(section["tts"])


def main():
    if len(sys.argv) < 2:
        print("Usage: python scripts/codex_enhance_script.py <slug>")
        return 2
    slug = sys.argv[1]
    path = CARDNEWS / "output" / slug / "shorts_script.json"
    if not path.exists():
        print(f"[codex_enhance] skip, not found: {path}")
        return 0

    data = json.loads(path.read_text(encoding="utf-8"))
    process_section(data.get("hook", {}))
    for fact in data.get("facts", []):
        process_section(fact)
    process_section(data.get("cta", {}))

    data["_codex_common_quality_logic"] = True
    data["_codex_sync_quality_logic"] = True
    data["_codex_common_quality_note"] = (
        "TTS, caption_chunks, and display_chunks keep the same meaning/order. "
        "display_chunks add only light Korean grammar for readable captions."
    )
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")
    print(f"[codex_enhance] OK sync mode: {slug}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
