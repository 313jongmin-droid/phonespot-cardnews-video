export function splitChunks(text: string, maxChars = 14): string[] {
  const words = text.split(/\s+/).filter(Boolean);
  const chunks: string[] = [];
  let cur = "";

  for (const word of words) {
    const merged = cur ? `${cur} ${word}` : word;
    if (merged.replace(/\s/g, "").length > maxChars && cur) {
      chunks.push(cur);
      cur = word;
    } else {
      cur = merged;
    }
  }

  if (cur) {
    chunks.push(cur);
  }
  return chunks;
}

export function chunkInfo(text: string, frame: number, durFrames: number, maxChars = 14) {
  const chunks = splitChunks(text, maxChars);
  const idx = chunkIndexFromList(chunks, frame, durFrames);
  return { chunks, idx, count: chunks.length };
}

export function chunkIndexFromList(chunks: string[], frame: number, durFrames: number) {
  const clean = chunks && chunks.length ? chunks : [""];
  const counts = clean.map((chunk) => Math.max(1, chunk.replace(/\s/g, "").length));
  const total = counts.reduce((sum, count) => sum + count, 0) || 1;

  let idx = 0;
  let acc = 0;
  for (let i = 0; i < counts.length; i++) {
    const start = (acc / total) * durFrames;
    if (frame >= start) {
      idx = i;
    }
    acc += counts[i];
  }

  return Math.min(idx, clean.length - 1);
}