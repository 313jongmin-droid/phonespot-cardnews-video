# =========================================================
# 폰스팟 광교점 SNS 업로드 자동화 - 환경 변수 템플릿
# ---------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해 .env 로 만든다 (cp .env.example .env)
#   2) 각 항목 값을 실제 발급 받은 값으로 채운다
#   3) .env 는 절대 git/외부 공유 금지 (.gitignore 에 포함됨)
# =========================================================

# ───── 공용 ─────
LITTLY=https://littly.com/phonespot-gwanggyo
PRECON_URL=https://ictmarket.or.kr/사전승낙서URL

# ───── 스레드 (Meta) ─────
# https://developers.facebook.com/apps/ 에서 앱 생성 후 Threads API 추가
META_APP_ID=
META_APP_SECRET=
THREADS_USER_ID=
# long-lived 토큰 (60일 만료) — Graph API Explorer 또는 토큰 교환 엔드포인트
THREADS_ACCESS_TOKEN=

# ───── 인스타그램 (Graph API) ─────
# 사전 조건: 비즈니스 계정 + Facebook 페이지 연동
# 권한: instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Page Access Token (long-lived)
INSTAGRAM_ACCESS_TOKEN=

# ───── 유튜브 (Data API v3) ─────
# https://console.cloud.google.com/ 에서 OAuth 클라이언트 발급 후
# 다운로드한 client_secret JSON 을 아래 경로에 저장
YOUTUBE_CLIENT_SECRETS_PATH=./tokens/yt_client_secret.json
YOUTUBE_CHANNEL_ID=

# ───── 틱톡 (Content Posting API) ─────
# https://developers.tiktok.com/ 에서 앱 등록
# Direct Post 권한은 별도 신청 (심사 1~2주, 대부분 첫 신청은 거절)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ───── 네이버 블로그 (반자동) ─────
# 공식 API 없음 — Chrome MCP / Playwright 반자동 게시
# 권장: 평문 저장 대신 Windows Credential Manager 사용
# (이 파일의 값은 fallback / 개발 편의용)
NAVER_ID=
NAVER_PW=

# ───── 이미지 호스팅 (Threads/Instagram 캐러셀용) ─────
# 로컬 파일은 게시 불가 → 공개 URL 필요
# 옵션 A: Cloudflare R2 (월 10GB 송신 무료, 권장)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# 옵션 B: 로컬 ngrok 터널 (개발/테스트용)
NGROK_AUTH_TOKEN=
LOCAL_HTTP_PORT=8000
